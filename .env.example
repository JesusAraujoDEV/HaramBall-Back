# ─────────────────────────────────────────────────────────────
# HaramBall backend — environment configuration template
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file (it is gitignored).
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL=postgresql://user:password@localhost:5432/database?schema=haramball

# Database schema name used by the application.
DATABASE_SCHEMA=haramball

# Secret used to sign JWT access tokens (use a long, random value).
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret

# Access-token lifetime (<= 60m). Examples: 15m, 30m, 60m
JWT_ACCESS_TTL=60m

# Refresh-token lifetime (<= 30d). Examples: 7d, 14d, 30d
REFRESH_TOKEN_TTL=30d

# Failed-authentication lockout threshold (number of failures).
AUTH_MAX_FAILED_ATTEMPTS=10

# Failed-authentication rolling window. Examples: 15m, 30m
AUTH_FAILED_WINDOW=15m

# Global request-rate limit: max requests per window per client.
RATE_LIMIT_MAX=100

# Request-rate limit window in seconds.
RATE_LIMIT_WINDOW=60

# Maximum accepted entry/body size in bytes (drives HTTP 413).
MAX_ENTRY_BYTES=65536

# HTTP port the server listens on.
PORT=3000
